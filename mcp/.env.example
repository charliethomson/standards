# Secrets for the MCP servers in this repo. Copy to `mcp/.env` and fill in.
# `mcp/.env` is gitignored; both servers source it at launch via .mcp.json.
# Non-secret values (GRAFANA_URL, KOMODO_HOST) live in .mcp.json, not here.

# Grafana service account token (Administration → Service accounts → Add token).
# Role Viewer is enough for querying.
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_...

# Komodo API key/secret (Settings → API Keys).
KOMODO_API_KEY=K-...
KOMODO_API_SECRET=S-...

# Opt in to deploy/restart/stop tools. Leave unset/empty to keep Komodo
# read-only (the default; deploys/syncs stay in your hands per CLAUDE.md).
#KOMODO_ALLOW_EXECUTE=1
